{
  "name": "api-test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "gen:api": "npm run gen:v1 && npm run gen:v2",
    "gen:v1": "openapi-generator generate -i http://localhost:5000/swagger/v1/swagger.json -g typescript-axios -o ./src/api/v1 --additional-properties=useSingleRequestParameter=true,withInterfaces=true,supportsES6=true",
    "gen:v2": "openapi-generator generate -i http://localhost:5000/swagger/v2/swagger.json -g typescript-axios -o ./src/api/v2 --additional-properties=useSingleRequestParameter=true,withInterfaces=true,supportsES6=true"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.1.5"
  }
}